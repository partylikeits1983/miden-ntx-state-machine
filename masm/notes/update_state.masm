use external_contract::state_machine

#! "Update state" note: when consumed, it calls into the state machine
#! account and triggers one full tick (increment counter + emit a fresh
#! identical update_state note tagged back at the account). After Alice
#! seeds a single one of these, the network keeps the chain alive on its
#! own.
@note_script
pub proc main
    # Drop note args if the executor pushed any.
    dropw

    call.state_machine::tick
end
